# Copy this file to .env and fill in your real keys.
# .env is git-ignored — never commit real keys.

DATABENTO_API_KEY=your_databento_key_here
DATABENTO_DATASET=XNAS.ITCH

QUANTDATA_API_KEY=your_quantdata_key_here

# Connection layer exists (server/aiProviders.js) and full analysis logic
# is wired up (server/analysis.js) — see docs/architecture.md.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
XAI_API_KEY=your_xai_key_here

# Trade storage (Postgres). On Railway, this is a variable REFERENCE to the
# Postgres service's DATABASE_URL (added via the Variables tab's picker),
# not a value you type by hand. Not available locally unless you run a
# local Postgres yourself.
DATABASE_URL=

GHOSTFLOW_USER=choose_a_username
GHOSTFLOW_PASS=choose_a_real_password
